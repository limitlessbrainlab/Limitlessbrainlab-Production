{
  "rewrites": [
    {
      "source": "/api/:path((?!send-report-email$).*)",
      "destination": "https://limitlessbrainlab-production-backend.onrender.com/api/:path"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(meditation-thumbs|brain-course)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    }
  ]
}